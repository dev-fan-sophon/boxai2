#!/usr/bin/env bash
set -euo pipefail

echo 'Checking BoxAI orb toolchain...'
for command_name in bun curl jq ssh tar; do
  command -v "$command_name" >/dev/null || {
    echo "Required command not found: $command_name" >&2
    exit 1
  }
done

verify_sha256() {
  local file=$1
  local expected=$2
  if command -v sha256sum >/dev/null; then
    printf '%s  %s\n' "$expected" "$file" | sha256sum --check --status
  elif command -v shasum >/dev/null; then
    [[ $(shasum -a 256 "$file" | awk '{print $1}') == "$expected" ]]
  else
    echo 'No SHA-256 verification command is available.' >&2
    exit 1
  fi
}

sudo_cmd=()
if [[ ! -w /usr/local ]]; then
  command -v sudo >/dev/null || {
    echo 'Toolchain installation requires write access to /usr/local or sudo.' >&2
    exit 1
  }
  sudo_cmd=(sudo)
fi

setup_tmp=$(mktemp -d)
trap 'rm -rf "$setup_tmp"' EXIT

if ! command -v go >/dev/null; then
  go_version=1.25.1
  case "$(uname -m)" in
    x86_64) go_arch=amd64 ;;
    aarch64|arm64) go_arch=arm64 ;;
    *) echo "Unsupported architecture for Go installation: $(uname -m)" >&2; exit 1 ;;
  esac

  go_archive="go${go_version}.linux-${go_arch}.tar.gz"
  echo "Installing Go ${go_version} for ${go_arch}..."
  curl --fail --location --silent --show-error \
    "https://go.dev/dl/${go_archive}" -o "$setup_tmp/$go_archive"
  expected_sha=$(curl --fail --location --silent --show-error \
    'https://go.dev/dl/?mode=json&include=all' |
    jq -er --arg filename "$go_archive" \
      '[.[] | .files[] | select(.filename == $filename) | .sha256][0]')
  verify_sha256 "$setup_tmp/$go_archive" "$expected_sha"
  "${sudo_cmd[@]}" rm -rf /usr/local/go
  "${sudo_cmd[@]}" tar -C /usr/local -xzf "$setup_tmp/$go_archive"
  "${sudo_cmd[@]}" ln -sf /usr/local/go/bin/go /usr/local/bin/go
  "${sudo_cmd[@]}" ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt
  hash -r
fi

if ! command -v gofmt >/dev/null; then
  "${sudo_cmd[@]}" ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt
  hash -r
fi

go version
gofmt --help >/dev/null

node_supported=false
if command -v node >/dev/null && node -e '
  const [major, minor] = process.versions.node.split(".").map(Number)
  process.exit((major === 20 && minor >= 19) || (major === 22 && minor >= 12) || major > 22 ? 0 : 1)
'; then
  node_supported=true
fi

if [[ "$node_supported" != true ]]; then
  node_version=22.17.0
  case "$(uname -m)" in
    x86_64) node_arch=x64 ;;
    aarch64|arm64) node_arch=arm64 ;;
    *) echo "Unsupported architecture for Node.js installation: $(uname -m)" >&2; exit 1 ;;
  esac

  node_archive="node-v${node_version}-linux-${node_arch}.tar.gz"
  echo "Installing Node.js ${node_version} for ${node_arch}..."
  curl --fail --location --silent --show-error \
    "https://nodejs.org/dist/v${node_version}/${node_archive}" -o "$setup_tmp/$node_archive"
  expected_sha=$(curl --fail --location --silent --show-error \
    "https://nodejs.org/dist/v${node_version}/SHASUMS256.txt" |
    awk -v filename="$node_archive" '$2 == filename {print $1}')
  [[ ${#expected_sha} -eq 64 ]] || {
    echo "Unable to resolve Node.js checksum for $node_archive." >&2
    exit 1
  }
  verify_sha256 "$setup_tmp/$node_archive" "$expected_sha"

  node_install="/usr/local/node-v${node_version}"
  "${sudo_cmd[@]}" rm -rf "$node_install"
  "${sudo_cmd[@]}" mkdir -p "$node_install"
  "${sudo_cmd[@]}" tar -C "$node_install" --strip-components=1 -xzf "$setup_tmp/$node_archive"
  "${sudo_cmd[@]}" ln -sf "$node_install/bin/node" /usr/local/bin/node
  hash -r
fi

node --version

echo 'Downloading Go modules...'
go mod download

echo 'Installing and building embedded web assets...'
(
  cd web
  bun install --frozen-lockfile
  (cd default && bun run build)
  # The production/default frontend is the supported orb build. main.go still
  # embeds the optional legacy theme, so provide the minimum embed target
  # without making orb setup depend on its incompatible date-fns dependency.
  mkdir -p classic/dist
  printf '<!doctype html><html><body>Classic theme is not built in Amp orbs.</body></html>\n' >classic/dist/index.html
)

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

if [[ -n ${BOXAI_SSH_PRIVATE_KEY:-} ]]; then
  key_file="$HOME/.ssh/boxai_orb_ed25519"
  umask 077
  if [[ "$BOXAI_SSH_PRIVATE_KEY" == -----BEGIN* ]]; then
    printf '%s\n' "$BOXAI_SSH_PRIVATE_KEY" >"$key_file"
  else
    printf '%s' "$BOXAI_SSH_PRIVATE_KEY" | base64 --decode >"$key_file"
  fi
  chmod 600 "$key_file"
  ssh-keygen -y -f "$key_file" >/dev/null
  echo 'Prepared BoxAI SSH key.'
else
  echo 'BOXAI_SSH_PRIVATE_KEY is not configured; production SSH will be unavailable.'
fi

if [[ -n ${BOXAI_SSH_HOST_KEY:-} ]]; then
  known_hosts="$HOME/.ssh/boxai_known_hosts"
  umask 077
  printf '%s\n' "$BOXAI_SSH_HOST_KEY" >"$known_hosts"
  chmod 600 "$known_hosts"
  echo 'Prepared pinned BoxAI SSH host key.'
else
  echo 'BOXAI_SSH_HOST_KEY is not configured; production SSH is intentionally blocked.'
fi

echo 'BoxAI orb setup complete.'
