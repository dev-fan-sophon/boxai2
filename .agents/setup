#!/usr/bin/env bash
set -euo pipefail

echo 'Checking BoxAI orb toolchain...'
for command_name in bun curl jq ssh tar; do
  command -v "$command_name" >/dev/null || {
    echo "Required command not found: $command_name" >&2
    exit 1
  }
done

if ! command -v go >/dev/null; then
  go_version=1.25.1
  case "$(uname -m)" in
    x86_64) go_arch=amd64 ;;
    aarch64|arm64) go_arch=arm64 ;;
    *) echo "Unsupported architecture for Go installation: $(uname -m)" >&2; exit 1 ;;
  esac

  go_archive="go${go_version}.linux-${go_arch}.tar.gz"
  go_tmp=$(mktemp -d)
  trap 'rm -rf "$go_tmp"' EXIT
  echo "Installing Go ${go_version} for ${go_arch}..."
  curl --fail --location --silent --show-error \
    "https://go.dev/dl/${go_archive}" -o "$go_tmp/$go_archive"
  curl --fail --location --silent --show-error \
    "https://go.dev/dl/${go_archive}.sha256" -o "$go_tmp/$go_archive.sha256"
  expected_sha=$(cat "$go_tmp/$go_archive.sha256")
  if command -v sha256sum >/dev/null; then
    printf '%s  %s\n' "$expected_sha" "$go_tmp/$go_archive" | sha256sum --check --status
  elif command -v shasum >/dev/null; then
    [[ $(shasum -a 256 "$go_tmp/$go_archive" | awk '{print $1}') == "$expected_sha" ]]
  else
    echo 'No SHA-256 verification command is available.' >&2
    exit 1
  fi

  sudo_cmd=()
  if [[ ! -w /usr/local ]]; then
    command -v sudo >/dev/null || {
      echo 'Go installation requires write access to /usr/local or sudo.' >&2
      exit 1
    }
    sudo_cmd=(sudo)
  fi
  "${sudo_cmd[@]}" rm -rf /usr/local/go
  "${sudo_cmd[@]}" tar -C /usr/local -xzf "$go_tmp/$go_archive"
  "${sudo_cmd[@]}" ln -sf /usr/local/go/bin/go /usr/local/bin/go
  hash -r
fi

go version

echo 'Downloading Go modules...'
go mod download

echo 'Installing and building embedded web assets...'
(
  cd web
  bun install --frozen-lockfile
  (cd default && bun run build)
  # The production/default frontend is the supported orb build. main.go still
  # embeds the optional legacy theme, so provide the minimum embed target
  # without making orb setup depend on its incompatible date-fns dependency.
  mkdir -p classic/dist
  printf '<!doctype html><html><body>Classic theme is not built in Amp orbs.</body></html>\n' >classic/dist/index.html
)

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

if [[ -n ${BOXAI_SSH_PRIVATE_KEY:-} ]]; then
  key_file="$HOME/.ssh/boxai_orb_ed25519"
  umask 077
  if [[ "$BOXAI_SSH_PRIVATE_KEY" == -----BEGIN* ]]; then
    printf '%s\n' "$BOXAI_SSH_PRIVATE_KEY" >"$key_file"
  else
    printf '%s' "$BOXAI_SSH_PRIVATE_KEY" | base64 --decode >"$key_file"
  fi
  chmod 600 "$key_file"
  ssh-keygen -y -f "$key_file" >/dev/null
  echo 'Prepared BoxAI SSH key.'
else
  echo 'BOXAI_SSH_PRIVATE_KEY is not configured; production SSH will be unavailable.'
fi

if [[ -n ${BOXAI_SSH_HOST_KEY:-} ]]; then
  known_hosts="$HOME/.ssh/boxai_known_hosts"
  umask 077
  printf '%s\n' "$BOXAI_SSH_HOST_KEY" >"$known_hosts"
  chmod 600 "$known_hosts"
  echo 'Prepared pinned BoxAI SSH host key.'
else
  echo 'BOXAI_SSH_HOST_KEY is not configured; production SSH is intentionally blocked.'
fi

echo 'BoxAI orb setup complete.'
