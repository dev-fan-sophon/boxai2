# BoxAI admin API + production SSH — copy to .env.boxai-admin (gitignored)
# Docs: docs/environment.md
# Amp orb: same keys in project Settings (see .agents/skills/managing-boxai-platform/reference/orb.md)

export BOXAI_BASE_URL=https://you-box.com
export BOXAI_ADMIN_USER_ID=
export BOXAI_ADMIN_TOKEN=

export BOXAI_SSH_HOST=
export BOXAI_SSH_PORT=22
export BOXAI_SSH_USER=boxai-deploy
export BOXAI_SSH_PRIVATE_KEY=
export BOXAI_SSH_HOST_KEY=

# ---------------------------------------------------------------------------
# Sub2API (subscription / account pool relay on BWG — NOT the BoxAI app itself)
# Public UI: https://sub2api.origingame.dev
# Admin HTTP: header X-API-Key: $SUB2API_ADMIN_API_KEY  (not Authorization Bearer)
# Host path: /opt/sub2api  SSH alias: bwg (or SUB2API_SSH_HOST)
# Simple mode hides /admin/groups in UI; manage groups via API or set RUN_MODE=standard.
# ---------------------------------------------------------------------------
export SUB2API_BASE_URL=https://sub2api.origingame.dev
export SUB2API_ADMIN_API_KEY=
export SUB2API_ADMIN_API_HEADER=X-API-Key
export SUB2API_ADMIN_EMAIL=
export SUB2API_ADMIN_PASSWORD=
# Relay keys (user sk-*; one group/platform each)
export SUB2API_KEY_CODEX=
export SUB2API_KEY_GROK=
export SUB2API_KEY_CLI=
export SUB2API_DEPLOY_DIR=/opt/sub2api
export SUB2API_SSH_HOST=bwg
export SUB2API_RUN_MODE=simple
